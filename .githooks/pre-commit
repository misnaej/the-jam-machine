#!/bin/bash
#
# Pre-commit hook for The Jam Machine
#
# Runs: ruff lint + format, docstring coverage, security audit, pip-audit
# All output is logged to .githooks/logs/ for debugging.
#
# To bypass this hook (not recommended), use: git commit --no-verify

set -e

# --- Setup logging ---
LOG_DIR=".githooks/logs"
mkdir -p "$LOG_DIR"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
LOG_FILE="$LOG_DIR/pre-commit-$TIMESTAMP.log"
LATEST_LINK="$LOG_DIR/latest.log"

# Tee all output to both terminal and log file
exec > >(tee -a "$LOG_FILE") 2>&1

echo "=== Pre-commit run: $(date) ==="
echo ""

# Update latest symlink
ln -sf "pre-commit-$TIMESTAMP.log" "$LATEST_LINK"

# Get staged Python files
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

FAILED=0

if [ -z "$STAGED_PY_FILES" ]; then
    echo "No Python files staged, skipping Python checks."
else
    # --- Ruff Linting ---
    echo "=== Ruff Linting ==="
    if ! pipenv run ruff check $STAGED_PY_FILES; then
        echo ""
        echo "Ruff found issues. Attempting auto-fix..."
        pipenv run ruff check --fix $STAGED_PY_FILES
        git add $STAGED_PY_FILES

        if ! pipenv run ruff check $STAGED_PY_FILES; then
            echo "ERROR: Ruff still found issues that couldn't be auto-fixed."
            FAILED=1
        else
            echo "Auto-fix successful. Files re-staged."
        fi
    fi
    echo ""

    # --- Ruff Formatting ---
    echo "=== Ruff Formatting ==="
    if ! pipenv run ruff format --check $STAGED_PY_FILES; then
        echo "Formatting issues found. Applying formatting..."
        pipenv run ruff format $STAGED_PY_FILES
        git add $STAGED_PY_FILES
        echo "Formatting applied. Files re-staged."
    fi
    echo ""

    # --- Docstring Coverage ---
    echo "=== Docstring Coverage (interrogate) ==="
    if command -v interrogate &> /dev/null || pipenv run interrogate --version &> /dev/null 2>&1; then
        if ! pipenv run interrogate src/jammy/ --fail-under 95 -q; then
            echo "ERROR: Docstring coverage below 95%. Missing docstrings:"
            pipenv run interrogate src/jammy/ -v | grep "MISS" || true
            FAILED=1
        fi
    else
        echo "interrogate not installed. Skipping. Install with: pipenv install -e '.[ci]'"
    fi
    echo ""

    # --- Security - Bandit ---
    echo "=== Security - Bandit ==="
    if command -v bandit &> /dev/null || pipenv run bandit --version &> /dev/null 2>&1; then
        if ! pipenv run bandit -r src/jammy/ -c pyproject.toml -q; then
            echo "ERROR: Bandit found security issues."
            echo "Run 'pipenv run bandit -r src/jammy/ -c pyproject.toml' for details."
            FAILED=1
        fi
    else
        echo "bandit not installed. Skipping. Install with: pipenv install -e '.[ci]'"
    fi
    echo ""
fi

if [ "$FAILED" -eq 0 ]; then
    echo "✓ Linting, formatting, docstring, and security checks passed"
else
    echo ""
    echo "✗ Pre-commit checks FAILED. See log: $LOG_FILE"
    exit 1
fi

# --- Security - pip-audit (informational, non-blocking) ---
echo ""
echo "=== Security - pip-audit (informational) ==="
if command -v pip-audit &> /dev/null || pipenv run pip-audit --version &> /dev/null 2>&1; then
    pipenv run pip-audit --progress-spinner off 2>/dev/null || echo "Note: pip-audit found potential vulnerabilities. Run 'pipenv run pip-audit' for details."
else
    echo "pip-audit not installed. Skipping."
fi

echo ""
echo "=== Result: PASS ==="
echo "✓ Pre-commit checks complete (log: $LOG_FILE)"
